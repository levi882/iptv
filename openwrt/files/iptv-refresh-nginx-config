#!/bin/sh
set -eu

# OpenWrt's /lib/functions.sh reads this package-manager variable directly.
# Runtime service calls do not define it, so initialize it before sourcing the
# library while nounset mode is active.
IPKG_INSTROOT="${IPKG_INSTROOT:-}"

AUTH_DIR=/etc/iptv-refresh/nginx.d
AUTH_FILE=$AUTH_DIR/auth.conf
AUTH_INCLUDE='/etc/iptv-refresh/nginx.d/*.conf'
LOCATIONS_FILE=/etc/nginx/conf.d/iptv-refresh.locations
DEFAULT_ALLOW=10.1.1.0/24

validate_token() {
	case "$1" in
		""|change-me|*[!A-Za-z0-9._~-]*)
			echo "ERROR: API token contains characters that cannot be embedded safely in nginx" >&2
			return 1
			;;
	esac
}

validate_allow() {
	case "$1" in
		""|*[!0-9A-Fa-f.:/]*)
			echo "ERROR: invalid nginx proxy allow address: $1" >&2
			return 1
			;;
	esac
}

validate_port() {
	case "$1" in
		""|*[!0-9]*) return 1 ;;
	esac
	[ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

validate_host() {
	host="$1"
	case "$host" in
		\[*\]) host="${host#\[}"; host="${host%\]}" ;;
	esac
	case "$host" in
		""|*[!0-9A-Fa-f.:]*)
			echo "ERROR: invalid IPTV Refresh listen address: $1" >&2
			return 1
			;;
	esac
}

render_auth() {
	token="$1"
	validate_token "$token"
	printf 'proxy_set_header Authorization "Bearer %s";\n' "$token"
}

render_legacy_locations() {
	with_comment="$1"
	printf '%s\n' \
		'# Nginx reverse proxy locations for IPTV Refresh.' \
		'' \
		'location = /iptv/refresh {'
	if [ "$with_comment" -eq 1 ]; then
		printf '%s\n' '    # Clients must use POST and send Authorization: Bearer <token>.'
	fi
	printf '%s\n' \
		'    proxy_pass http://127.0.0.1:9100/refresh$is_args$args;' \
		'    proxy_http_version 1.1;' \
		'    proxy_set_header Host $host;' \
		'    proxy_set_header Connection "";' \
		'}' \
		'' \
		'location = /iptv/healthz {' \
		'    proxy_pass http://127.0.0.1:9100/healthz;' \
		'    proxy_http_version 1.1;' \
		'    proxy_set_header Host $host;' \
		'    proxy_set_header Connection "";' \
		'}'
}

render_locations_file() {
	listen_host="$1"
	listen_port="$2"
	allow_file="$3"
	validate_host "$listen_host"
	validate_port "$listen_port" || {
		echo "ERROR: invalid IPTV Refresh listen port: $listen_port" >&2
		return 1
	}
	case "$listen_host" in
		""|0.0.0.0) upstream_host=127.0.0.1 ;;
		::|\[::\]) upstream_host='[::1]' ;;
		\[*\]) upstream_host="$listen_host" ;;
		*:*) upstream_host="[$listen_host]" ;;
		*) upstream_host="$listen_host" ;;
	esac

	printf '%s\n' \
		'# Generated by iptv-refresh-nginx-config. Do not edit.' \
		'location = /iptv/refresh {'
	while IFS= read -r allow; do
		[ -n "$allow" ] || continue
		validate_allow "$allow"
		printf '\tallow %s;\n' "$allow"
	done < "$allow_file"
	printf '\t%s\n' \
		'deny all;' \
		"include $AUTH_INCLUDE;" \
		'proxy_method POST;' \
		'proxy_pass_request_body off;' \
		'proxy_set_header Content-Length "";' \
		'proxy_set_header Host $host;' \
		'proxy_set_header Connection "";' \
		'proxy_http_version 1.1;' \
		"proxy_pass http://$upstream_host:$listen_port/refresh?;"
	printf '%s\n' '}' '' 'location = /iptv/healthz {'
	while IFS= read -r allow; do
		[ -n "$allow" ] || continue
		printf '\tallow %s;\n' "$allow"
	done < "$allow_file"
	printf '\t%s\n' \
		'deny all;' \
		'proxy_set_header Host $host;' \
		'proxy_set_header Connection "";' \
		'proxy_http_version 1.1;' \
		"proxy_pass http://$upstream_host:$listen_port/healthz;"
	printf '%s\n' '}'
}

install_if_changed() {
	tmp="$1"
	target="$2"
	mode="$3"
	if [ -r "$target" ] && cmp -s "$tmp" "$target"; then
		chmod "$mode" "$target"
		rm -f "$tmp"
		return 0
	fi
	chmod "$mode" "$tmp"
	mv -f "$tmp" "$target"
	changed=1
}

migrate_legacy_locations() {
	legacy_without_comment="$1"
	legacy_with_comment="$2"
	for candidate in /etc/nginx/conf.d/*.locations; do
		[ -e "$candidate" ] || continue
		if grep -q '^# Generated by iptv-refresh-nginx-config\.' "$candidate" 2>/dev/null; then
			continue
		fi
		grep -Eq 'location[[:space:]]*=[[:space:]]*/iptv/refresh[[:space:]]*\{' "$candidate" 2>/dev/null || continue
		if ! cmp -s "$candidate" "$legacy_without_comment" && ! cmp -s "$candidate" "$legacy_with_comment"; then
			echo "ERROR: custom nginx refresh route conflicts with generated proxy: $candidate" >&2
			return 1
		fi
		backup="${candidate}.iptv-refresh-legacy"
		[ ! -e "$backup" ] || {
			echo "ERROR: legacy nginx backup already exists: $backup" >&2
			return 1
		}
	done
	for candidate in /etc/nginx/conf.d/*.locations; do
		[ -e "$candidate" ] || continue
		if grep -q '^# Generated by iptv-refresh-nginx-config\.' "$candidate" 2>/dev/null; then
			continue
		fi
		grep -Eq 'location[[:space:]]*=[[:space:]]*/iptv/refresh[[:space:]]*\{' "$candidate" 2>/dev/null || continue
		backup="${candidate}.iptv-refresh-legacy"
		mv "$candidate" "$backup"
		changed=1
	done
}

restore_legacy_locations() {
	for backup in /etc/nginx/conf.d/*.locations.iptv-refresh-legacy; do
		[ -e "$backup" ] || continue
		original="${backup%.iptv-refresh-legacy}"
		[ -e "$original" ] || {
			mv "$backup" "$original"
			changed=1
		}
	done
}

generate() {
	. /lib/functions.sh
	config_load iptv-refresh
	config_get_bool proxy_enabled main nginx_proxy 1
	if [ "$proxy_enabled" -ne 1 ]; then
		changed=0
		for target in "$AUTH_FILE" "$LOCATIONS_FILE"; do
			if [ -e "$target" ]; then
				rm -f "$target"
				changed=1
			fi
		done
		rmdir "$AUTH_DIR" 2>/dev/null || true
		restore_legacy_locations
		[ "$changed" -eq 1 ] && echo changed || echo unchanged
		return 0
	fi

	config_get token_file main token_file /etc/iptv-refresh/token
	config_get listen_host main listen_host 127.0.0.1
	config_get listen_port main listen_port 9100
	IFS= read -r token < "$token_file" || token=
	validate_token "$token"

	mkdir -p "$AUTH_DIR" "$(dirname "$LOCATIONS_FILE")"
	chmod 0700 "$AUTH_DIR"
	auth_tmp="${AUTH_FILE}.tmp.$$"
	locations_tmp="${LOCATIONS_FILE}.tmp.$$"
	allow_tmp="/tmp/iptv-refresh-nginx-allow.$$"
	legacy_without_comment="/tmp/iptv-refresh-nginx-legacy-0.$$"
	legacy_with_comment="/tmp/iptv-refresh-nginx-legacy-1.$$"
	trap 'rm -f "$auth_tmp" "$locations_tmp" "$allow_tmp" "$legacy_without_comment" "$legacy_with_comment"' EXIT HUP INT TERM
	: > "$allow_tmp"
	append_allow() {
		validate_allow "$1"
		printf '%s\n' "$1" >> "$allow_tmp"
	}
	config_list_foreach main nginx_allow_ip append_allow
	if [ ! -s "$allow_tmp" ]; then
		printf '%s\n' "$DEFAULT_ALLOW" > "$allow_tmp"
	fi

	umask 077
	render_auth "$token" > "$auth_tmp"
	render_locations_file "$listen_host" "$listen_port" "$allow_tmp" > "$locations_tmp"
	changed=0
	render_legacy_locations 0 > "$legacy_without_comment"
	render_legacy_locations 1 > "$legacy_with_comment"
	migrate_legacy_locations "$legacy_without_comment" "$legacy_with_comment"
	install_if_changed "$auth_tmp" "$AUTH_FILE" 0600
	install_if_changed "$locations_tmp" "$LOCATIONS_FILE" 0644
	rm -f "$allow_tmp" "$legacy_without_comment" "$legacy_with_comment"
	trap - EXIT HUP INT TERM
	unset token
	[ "$changed" -eq 1 ] && echo changed || echo unchanged
}

action="${1:-generate}"
case "$action" in
	generate)
		generate
		;;
	render-auth)
		[ "$#" -eq 2 ] || { echo "Usage: $0 render-auth TOKEN" >&2; exit 2; }
		render_auth "$2"
		;;
	render-locations)
		[ "$#" -ge 3 ] || { echo "Usage: $0 render-locations HOST PORT [ALLOW ...]" >&2; exit 2; }
		host="$2"
		port="$3"
		shift 3
		allow_tmp="/tmp/iptv-refresh-nginx-render.$$"
		trap 'rm -f "$allow_tmp"' EXIT HUP INT TERM
		: > "$allow_tmp"
		for allow in "$@"; do
			validate_allow "$allow"
			printf '%s\n' "$allow" >> "$allow_tmp"
		done
		if [ ! -s "$allow_tmp" ]; then
			printf '%s\n' "$DEFAULT_ALLOW" > "$allow_tmp"
		fi
		render_locations_file "$host" "$port" "$allow_tmp"
		rm -f "$allow_tmp"
		trap - EXIT HUP INT TERM
		;;
	*)
		echo "Usage: $0 <generate|render-auth|render-locations>" >&2
		exit 2
		;;
esac
