# Fixed provider settings. Dynamic credentials and discovered portal endpoints
# are stored separately in provider.creds.env.
IFACE=any
PROVIDER_TOKEN_SERVER=auto
PROVIDER_PLATFORM_ORIGIN=auto
PROVIDER_EPG_ENTRY=auto
PROVIDER_EPG_ENTRY_FALLBACKS=
PROVIDER_EASIP=auto
PROVIDER_NETWORKID=auto
PROVIDER_CITYCODE=
PROVIDER_STB_TYPE=auto
PROVIDER_PRMID=auto
PROVIDER_DRM_SUPPLIER=auto
PROVIDER_BIND_INTERFACE=auto
PROVIDER_BIND_SOURCE_IP=
PROVIDER_USER_AGENT=auto
PROVIDER_TIMEOUT=20
CREDS_FILE=/etc/iptv-refresh/provider.creds.env
CAPTURE_TIMEOUT=180
REFRESH_TIMEOUT=300
DUMP_PATH=
MODE=auto
OUTPUT_FORMAT=m3u
OUTPUT_PATH=/mnt/iptv/iptv-refresh/config/local/local_stb.m3u
R2H_SNAPSHOT_OUTPUT_PATH=/mnt/iptv/iptv-refresh/config/local/local_stb.snapshot.m3u
SORT_BY=user_channel_id
USE_CACHE=1
EPG_URL=http://epg.51zmt.top:8000/e1.xml.gz
EPG_FILE=/mnt/iptv/iptv-refresh/cache/e1.xml.gz
EPG_PUBLIC_FILE=/www/iptv_epg/e1.xml.gz
X_TVG_URL=
R2H_BASE_URL=
R2H_IGMP_PATH=udp
R2H_ADD_FCC=1
R2H_FCC_TYPE=telecom
R2H_PROXY_RTSP=1
R2H_CATCHUP_HOST=
CATCHUP_TYPE=shift
CATCHUP_PLAYSEEK_TEMPLATE="{(b)YmdHMS}-{(e)YmdHMS}"
CATCHUP_SEEK_OFFSET=-900
LINE_TAG_RULE=hd_sd
LINE_TAG_UHD=超高清
LINE_TAG_HD=高清
LINE_TAG_SD=标清
LOGO_MATCH_SOURCE=https://live.fanmingming.com/tv/m3u/index.m3u
LOGO_URL_BASE=
LOGO_OVERRIDES_FILE=/mnt/iptv/iptv-refresh/config/local/logo_overrides.csv
LOGO_MATCH_THRESHOLD=0.65
LOCAL_LOGO_CACHE=1
LOCAL_LOGO_DIR=/www/iptv_logo
LOCAL_LOGO_URL_BASE=
GROUP_BY_51ZMT=1
DISPLAY_NAME_MODE=tvg_name
