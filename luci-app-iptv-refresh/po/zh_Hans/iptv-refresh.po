msgstr "直播流偏好"

msgid "Structured editor for playlist, rtp2httpd, EPG, logo, catch-up, and provider options. Unknown variables and comments in the provider environment file are preserved."
msgstr "用于编辑播放列表、rtp2httpd、EPG、台标、回看和运营商选项的结构化界面。运营商环境配置文件中的未知变量和注释会被保留。"

msgid "The service returned an invalid status response"
msgstr "服务返回了无效的状态响应"

msgid "The token is managed by the backend and is not displayed in LuCI."
msgstr "令牌由后端管理，不会显示在 LuCI 中。"

msgid "Timeshift channels"
msgstr "回看频道数"

msgid "The normal refresh does not require the STB. Use credential capture only after saved credentials expire, and keep the STB powered on while capturing."
msgstr "普通刷新不需要开启机顶盒。仅在已保存凭据失效后重新抓取，抓取期间请保持机顶盒开机。"

msgid "Token server"
msgstr "令牌服务器"

msgid "UHD tag"
msgstr "超高清标签"

msgid "Unable to secure the environment file"
msgstr "无法设置环境配置文件的安全权限"

msgid "Unmatched channels"
msgstr "未匹配频道"

msgid "Use 51zmt groups"
msgstr "使用 51zmt 分组"

msgid "Use auto to prefer captured values."
msgstr "使用 auto 可优先采用捕获到的值。"

msgid "Use cached provider data"
msgstr "使用缓存的运营商数据"

msgid "Use the host and port configured under rtp2httpd Listen Addresses, for example http://router.lan:5140."
msgstr "使用 rtp2httpd“监听地址”中配置的主机和端口，例如 http://router.lan:5140。"

msgid "User channel ID"
msgstr "用户频道 ID"

msgid "rtp2httpd"
msgstr "rtp2httpd"

msgid "rtp2httpd base URL"
msgstr "rtp2httpd 基础 URL"

msgid "unknown"
msgstr "未知"

msgid "Provider HTTP interface"
msgstr "运营商 HTTP 接口"

msgid "Logical interface used for provider authentication and channel downloads. Raw VLAN and any capture interfaces usually have no IPv4, so select the addressed DHCP/PPPoE IPTV interface explicitly. An explicit provider interface override under Environment takes precedence."
msgstr "用于运营商认证和下载频道的逻辑接口。原始 VLAN 和“所有接口”通常没有 IPv4 地址，因此请明确选择已获取地址的 DHCP/PPPoE IPTV 接口；环境页面中的运营商接口覆盖设置优先。"

msgid "Follow capture interface"
msgstr "跟随抓包接口"

msgid "Follow routing table"
msgstr "跟随系统路由表"

msgid "Overall refresh timeout"
msgstr "刷新总超时时间"

msgid "Maximum seconds for one complete refresh, including credential capture."
msgstr "一次完整刷新的最长秒数，包括凭据抓取。"

msgid "Optional diagnostic file containing sensitive raw provider traffic. Leave empty for normal use."
msgstr "可选的诊断文件，其中包含敏感的运营商原始流量；正常使用时请留空。"

msgid "Home Assistant compatibility proxy"
msgstr "Home Assistant 兼容代理"

msgid "Automatically inject the router API token, convert legacy GET refresh requests to POST, and ignore legacy query parameters."
msgstr "自动注入路由器 API 令牌，将旧版 GET 刷新请求转换为 POST，并忽略旧版查询参数。"

msgid "Home Assistant proxy source addresses"
msgstr "Home Assistant 代理来源地址"

msgid "Log limit"
msgstr "日志上限"

msgid "50 lines"
msgstr "50 行"

msgid "100 lines"
msgstr "100 行"

msgid "200 lines"
msgstr "200 行"

msgid "500 lines"
msgstr "500 行"

msgid "1000 lines"
msgstr "1000 行"

msgid "Clear log"
msgstr "清理日志"

msgid "IPTV Refresh log cleared."
msgstr "IPTV Refresh 日志已清理。"

msgid "Log limit updated to %s lines."
msgstr "日志上限已更新为 %s 行。"

msgid "Log size limit"
msgstr "日志大小上限"

msgid "Log size limit updated to %s %s."
msgstr "日志大小上限已更新为 %s %s。"

msgid "STB automation"
msgstr "机顶盒自动化"

msgid "Restart rtp2httpd after credential capture"
msgstr "抓取凭据后重启 rtp2httpd"

msgid "After a successful credential capture and playlist refresh, restart rtp2httpd. Normal saved-credential refreshes do not restart it."
msgstr "成功抓取凭据并刷新播放列表后重启 rtp2httpd；使用已保存凭据的普通刷新不会重启它。"

msgid "Power on STB through Home Assistant"
msgstr "通过 Home Assistant 开启机顶盒"

msgid "During credential recapture, start packet capture first and then call the configured Home Assistant webhook. Normal saved-credential refreshes never call it."
msgstr "重新抓取凭据时先启动抓包，再调用配置的 Home Assistant Webhook；使用已保存凭据的普通刷新不会调用它。"

msgid "Home Assistant webhook URL"
msgstr "Home Assistant Webhook 地址"

msgid "Use a local-only Home Assistant webhook such as http://homeassistant.lan:8123/api/webhook/your-random-id. The URL is treated as a secret and is not placed on the service command line."
msgstr "请使用仅限本地访问的 Home Assistant Webhook，例如 http://homeassistant.lan:8123/api/webhook/随机ID。该地址按敏感信息处理，不会出现在服务命令行中。"

msgid "Home Assistant webhook timeout"
msgstr "Home Assistant Webhook 超时"

msgid "Seconds to wait for Home Assistant to accept the power-on request."
msgstr "等待 Home Assistant 接受开机请求的秒数。"

msgid "The normal refresh does not require the STB. During credential capture, a configured Home Assistant webhook is called after packet capture starts; otherwise power on the STB manually."
msgstr "普通刷新不需要机顶盒。抓取凭据时，程序会在抓包启动后调用已配置的 Home Assistant Webhook；未配置时请手动开启机顶盒。"

msgid "Only these IP addresses or CIDR networks may use the token-injecting nginx refresh route. Prefer the exact Home Assistant IP when it is static."
msgstr "仅允许这些 IP 地址或 CIDR 网段使用自动注入令牌的 nginx 刷新路由。Home Assistant 使用静态地址时，建议只填写其准确 IP。"

msgid "All interfaces"
msgstr "所有接口"

msgid "STB type"
msgstr "机顶盒型号"

msgid "STB PRMID"
msgstr "机顶盒 PRMID"

msgid "STB DRM supplier"
msgstr "机顶盒 DRM 提供商"

msgid "Use auto to replay the value captured from the STB."
msgstr "使用 auto 可重放从机顶盒捕获到的值。"

msgid "Use auto to discover the value during credential capture."
msgstr "使用 auto 可在抓取凭据时自动发现该值。"

msgid "Scheduled credential capture and refresh"
msgstr "定时捕获凭据并刷新"

msgid "Run credential capture followed by a full channel and EPG refresh on the router schedule. Enable the Home Assistant power-on webhook above or ensure the STB is powered on at that time."
msgstr "按路由器计划先捕获凭据，再完整刷新频道和 EPG。请启用上方的 Home Assistant 开机 Webhook，或确保届时机顶盒已经开机。"

msgid "Cron expression"
msgstr "Cron 表达式"

msgid "Use five numeric fields: minute, hour, day of month, month, and day of week. The router local time zone is used. For example, 30 7 * * * runs every day at 07:30."
msgstr "使用 5 个数字字段：分钟、小时、日期、月份和星期。时间以路由器本地时区为准。例如，30 7 * * * 表示每天 07:30 运行。"

msgid "Enter a five-field numeric cron expression."
msgstr "请输入包含 5 个数字字段的 Cron 表达式。"

msgid "Cron expression contains a value outside its valid range."
msgstr "Cron 表达式包含超出有效范围的值。"
