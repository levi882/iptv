msgstr "尚未运行"

msgid "Only these source addresses may call status, refresh, and playlist endpoints. Keep loopback entries for LuCI integration."
msgstr "仅允许这些源地址调用状态、刷新和播放列表端点。请保留环回地址，以便 LuCI 正常集成。"

msgid "Optional direct HTTP prefix used instead of rtp2httpd URL generation."
msgstr "可选的直接 HTTP 前缀，用于替代 rtp2httpd URL 生成。"

msgid "Optional local file or URL used for channel-name matching."
msgstr "可选的本地文件或 URL，用于匹配频道名称。"

msgid "Optional local or remote playlist used as ordering reference."
msgstr "可选的本地或远程播放列表，用作排序参考。"

msgid "Optional playlist with rtp2httpd snapshot URLs."
msgstr "可选的播放列表，其中包含 rtp2httpd 快照 URL。"

