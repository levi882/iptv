#!/bin/sh
set -e

. /lib/functions.sh

config_load iptv-refresh
config_get listen_host main listen_host 127.0.0.1
config_get listen_port main listen_port 9100
config_get token_file main token_file /etc/iptv-refresh/token
config_get iface main iface eth3.3927

action="${1:-}"
case "$action" in
	refresh)
		exec /usr/bin/iptv-refresh control refresh \
			--host "$listen_host" \
			--port "$listen_port" \
			--token-file "$token_file" \
			--iface "$iface"
		;;
	capture-refresh)
		exec /usr/bin/iptv-refresh control refresh \
			--host "$listen_host" \
			--port "$listen_port" \
			--token-file "$token_file" \
			--iface "$iface" \
			--capture
		;;
	chmod-env)
		# The LuCI editor is intentionally restricted to this exact path by
		# rpcd ACL. Do not derive a chmod target from writable UCI data.
		chmod 0600 /etc/iptv-refresh/hb.env
		;;
	*)
		echo "Usage: $0 <refresh|capture-refresh|chmod-env>" >&2
		exit 2
		;;
esac
