#!/bin/sh
set -e

. /lib/functions.sh

config_load iptv-refresh
config_get listen_host main listen_host 127.0.0.1
config_get listen_port main listen_port 9100
config_get token_file main token_file /etc/iptv-refresh/token
config_get iface main iface any
config_get repo_root main repo_root /mnt/iptv/iptv-refresh
config_get log_max_size main log_max_size 1M
log_file="${repo_root%/}/output/log/iptv_refresh.log"

action="${1:-}"
case "$action" in
	health|status|playlist)
		exec /usr/bin/iptv-refresh control "$action" \
			--host "$listen_host" \
			--port "$listen_port" \
			--token-file "$token_file" \
			--iface "$iface"
		;;
	version)
		exec /usr/bin/iptv-refresh version
		;;
	log)
		[ -r "$log_file" ] || exit 0
		exec tail -n 200 "$log_file"
		;;
	log-max-size)
		printf '%s\n' "$log_max_size"
		;;
	*)
		echo "Usage: $0 <health|status|playlist|version|log|log-max-size>" >&2
		exit 2
		;;
esac
