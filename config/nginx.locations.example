# Reference output. The OpenWrt package generates this location automatically.
# Prefer one exact Home Assistant address (192.0.2.50 is a documentation example).

location = /iptv/refresh {
    allow 192.0.2.50;
    deny all;
    include /etc/iptv-refresh/nginx.d/*.conf;
    proxy_method POST;
    proxy_pass_request_body off;
    proxy_set_header Content-Length "";
    proxy_set_header Host $host;
    proxy_set_header Connection "";
    proxy_http_version 1.1;
    proxy_pass http://127.0.0.1:9100/refresh?;
}

location = /iptv/healthz {
    allow 192.0.2.50;
    deny all;
    proxy_set_header Host $host;
    proxy_set_header Connection "";
    proxy_http_version 1.1;
    proxy_pass http://127.0.0.1:9100/healthz;
}
